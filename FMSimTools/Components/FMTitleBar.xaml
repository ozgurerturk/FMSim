<UserControl x:Class="FMSimTools.Components.FMTitleBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FMSimTools.Components"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="36" d:DesignWidth="800">
    <Grid>
        <ui:TitleBar CanMaximize="True"
                     Background="#FF616161"
                     MaxHeight="30">
            <ui:TitleBar.Header>
                <ui:TextBlock Text="{Binding Title, ElementName=Root}"
                              Foreground="White"
                              VerticalAlignment="Center"
                              Margin="10 0 0 0"
                              IsHitTestVisible="False"
                              FontSize="14"
                              FontFamily="Var" />
            </ui:TitleBar.Header>
        </ui:TitleBar>
    </Grid>
</UserControl>
