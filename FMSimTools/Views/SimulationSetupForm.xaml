<ui:FluentWindow x:Class="FMSimTools.Views.SimulationSetupForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FMSimTools.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:components="clr-namespace:FMSimTools.Components"
        d:DataContext="{d:DesignInstance Type=viewmodels:SimulationSetupViewModel}"
        mc:Ignorable="d"
        Title="Kick Off"
        Height="430"
        Width="460"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <components:FMTitleBar Grid.Row="0" Title="Kick Off" />

        <StackPanel Grid.Row="1" Margin="18">
            <ui:TextBlock Text="Home Team" />
            <ComboBox ItemsSource="{Binding Teams}"
                      SelectedItem="{Binding SelectedHomeTeam, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Margin="0 4 0 14" />

            <ui:TextBlock Text="Away Team" />
            <ComboBox ItemsSource="{Binding Teams}"
                      SelectedItem="{Binding SelectedAwayTeam, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Margin="0 4 0 14" />

            <ui:TextBlock Text="Simulation Minutes" />
            <ComboBox ItemsSource="{Binding AvailableSimulationMinutes}"
                      SelectedItem="{Binding SelectedSimulationMinutes, Mode=TwoWay}"
                      Margin="0 4 0 14" />

            <ui:TextBlock Text="Match Count" />
            <ui:TextBox Text="{Binding SimulationCount, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0 4 0 14" />

            <ui:TextBlock Text="{Binding StatusMessage}"
                          TextWrapping="Wrap"
                          Foreground="#667085" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="18">
            <ui:Button Content="Cancel"
                       Width="90"
                       Margin="0 0 8 0"
                       Command="{Binding CancelCommand}" />
            <ui:Button Content="Start Simulation"
                       Width="140"
                       Appearance="Primary"
                       Command="{Binding StartSimulationCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
