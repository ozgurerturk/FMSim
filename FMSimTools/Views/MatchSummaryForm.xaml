<ui:FluentWindow x:Class="FMSimTools.Views.MatchSummaryForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FMSimTools.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:components="clr-namespace:FMSimTools.Components"
        d:DataContext="{d:DesignInstance Type=viewmodels:MatchSummaryViewModel}"
        mc:Ignorable="d"
        Title="Match Summary"
        Height="640"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <components:FMTitleBar Grid.Row="0" Title="Match Summary" />

        <StackPanel Grid.Row="1" Margin="18 14 18 8">
            <ui:TextBlock Text="Commentary"
                          FontSize="22"
                          FontWeight="SemiBold" />
            <ui:TextBlock Text="{Binding CommentaryPath}"
                          Margin="0 4 0 0"
                          FontSize="11"
                          Foreground="#667085"
                          TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="18 0 18 18"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ui:TextBlock Text="{Binding CommentaryText}"
                              TextWrapping="Wrap"
                              Margin="16"
                              FontSize="14"
                              LineHeight="22" />
            </ScrollViewer>
        </Border>
    </Grid>
</ui:FluentWindow>
