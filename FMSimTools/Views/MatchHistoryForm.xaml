<ui:FluentWindow x:Class="FMSimTools.Views.MatchHistoryForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FMSimTools.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:components="clr-namespace:FMSimTools.Components"
        d:DataContext="{d:DesignInstance Type=viewmodels:MatchHistoryViewModel}"
        mc:Ignorable="d"
        Title="Match History"
        Height="560"
        Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <components:FMTitleBar Grid.Row="0" Title="Match History" />

        <Grid Grid.Row="1" Margin="18 14 18 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Text="{Binding StatusMessage}"
                          VerticalAlignment="Center"
                          Foreground="#667085" />
            <ui:Button Grid.Column="1"
                       Content="Refresh"
                       Margin="0 0 8 0"
                       Command="{Binding RefreshHistoryCommand}" />
            <ui:Button Grid.Column="2"
                       Content="Open Match"
                       Appearance="Primary"
                       Command="{Binding OpenSelectedMatchCommand}" />
        </Grid>

        <Border Grid.Row="2"
                Margin="18 0"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8">
            <ui:ListView ItemsSource="{Binding Matches}"
                         SelectedItem="{Binding SelectedMatch, Mode=TwoWay}"
                         BorderThickness="0"
                         Margin="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="58" Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ui:TextBlock Text="{Binding DisplayName}"
                                          FontWeight="SemiBold"
                                          FontSize="13" />
                            <ui:TextBlock Grid.Row="1"
                                          FontSize="11"
                                          Foreground="#667085">
                                <Run Text="{Binding PlayedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding SourceFolder, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding Length, Mode=OneWay}" />
                                <Run Text=" bytes" />
                            </ui:TextBlock>
                        </Grid>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </Border>

        <ui:TextBlock Grid.Row="3"
                      Text="History is loaded from Logs and Teams/Logs commentary files."
                      Margin="18 10 18 18"
                      FontSize="11"
                      Foreground="#667085" />
    </Grid>
</ui:FluentWindow>
