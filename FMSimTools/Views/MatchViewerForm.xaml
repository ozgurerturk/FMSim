<ui:FluentWindow x:Class="FMSimTools.Views.MatchViewerForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FMSimTools.Views"
        xmlns:viewmodels="clr-namespace:FMSimTools.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:components="clr-namespace:FMSimTools.Components"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        Title="MatchViewerForm" Height="654" Width="1085">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*" />
            <ColumnDefinition Width="15*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <components:FMTitleBar Grid.Row="0" Grid.ColumnSpan="4" Title="Live Match" />

        <StackPanel Grid.Row="1" Grid.Column="1">
            <ui:Button Content="{Binding PauseContinueButtonText}"
           Grid.Column="1" Grid.Row="1"
           Width="140" Margin="0 8 0 0"
           Command="{Binding PauseCommand}" />

            <ui:Button Content="Stop Simulation"
           Grid.Column="1" Grid.Row="1"
           Width="140" Margin="0 8 0 0"
           Command="{Binding StopCommand}" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Grid.Row="1"
                    Margin="0 12 0 8"
                    HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="{Binding HomeTeamName}"
                           FontWeight="SemiBold"
                           FontSize="16" />
                <TextBlock Text="{Binding ScoreLine}"
                           Margin="16 0"
                           FontWeight="Bold"
                           FontSize="16" />
                <TextBlock Text="{Binding AwayTeamName}"
                           FontWeight="SemiBold"
                           FontSize="16" />
            </StackPanel>
            <TextBlock Text="{Binding CurrentCommentary}"
                       Margin="0 8 0 0"
                       Width="520"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="14" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0 4 0 0"
                       HorizontalAlignment="Center"
                       Foreground="#667085" />
        </StackPanel>

        <Viewbox Grid.Column="2"
         Grid.Row="2"
         HorizontalAlignment="Center">
            <Grid Width="223"
                  Height="150">

                <Image x:Name="imgPitch"
                       Source="/Football_field.png"
                       Stretch="Uniform"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1.4" ScaleY="1.4" />
                            <SkewTransform />
                            <RotateTransform Angle="90" />
                            <TranslateTransform />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <ItemsControl HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ItemsSource="{Binding PitchZones}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="3" Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <TextBlock Text="{Binding Name}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFF7B500" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>
    </Grid>
</ui:FluentWindow>
