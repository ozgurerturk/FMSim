<ui:FluentWindow x:Class="FMSimTools.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FMSimTools"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:components="clr-namespace:FMSimTools.Components"
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="820">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <components:FMTitleBar Grid.Row="0"
                               Grid.ColumnSpan="5"
                               Title="FMSim Tools" />

        <StackPanel Grid.Row="2"
                    Grid.Column="1">
            <ui:TextBlock Text="Teams"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0 0 0 12" />
            <ui:Button Content="Create Team"
                       Width="140"
                       Appearance="Success"
                       Command="{Binding CreateTeamCommand}" />
            <ui:Button Content="Kick Off"
                       Width="140"
                       Margin="0 8 0 0"
                       Appearance="Primary"
                       Command="{Binding KickOffCommand}" />
            <ui:Button Content="Match History"
                       Width="140"
                       Margin="0 8 0 0"
                       Command="{Binding MatchHistoryCommand}" />
            <ui:Button Content="Open Match Viewer"
                       Width="140"
                       Margin="0 8 0 0"
                       Command="{Binding MatchViewerCommand}" />
            <ui:Button Content="Refresh"
                       Width="140"
                       Margin="0 8 0 0"
                       Command="{Binding RefreshTeamsCommand}" />
            <ui:TextBlock Text="{Binding TeamListStatusMessage}"
                          Margin="0 16 0 0"
                          Foreground="#667085" />
        </StackPanel>

        <Border Grid.Row="2"
                Grid.Column="3"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Text="Existing Teams"
                                  FontSize="16"
                                  FontWeight="SemiBold" />
                    <ui:Button Grid.Column="1"
                               Content="Open Details"
                               Command="{Binding OpenSelectedTeamCommand}" />
                </Grid>

                <ui:ListView Grid.Row="1"
                             ItemsSource="{Binding Teams}"
                             SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                             BorderThickness="0"
                             Margin="8 0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="54" Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock Text="{Binding Name}"
                                              FontWeight="SemiBold"
                                              FontSize="13" />
                                <ui:TextBlock Grid.Row="1"
                                              FontSize="11"
                                              Foreground="#667085">
                                    <Run Text="{Binding AttackTactic}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding DefenseTactic}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding Players.Count, Mode=OneWay}" />
                                    <Run Text=" players" />
                                </ui:TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>

                <ui:TextBlock Grid.Row="2"
                              Text="Select a team and open details to edit it in Team Viewer."
                              Margin="14 10"
                              FontSize="11"
                              Foreground="#667085" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
